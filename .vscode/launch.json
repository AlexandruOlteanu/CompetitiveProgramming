{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "g++ - Build and debug active file",
            "type": "cppdbg",
            "request": "launch",
            "args": ["<", "input.in"],
            "stopAtEntry": true,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build Current File",
            "windows": {
                "program": "${fileDirname}\\executables\\${fileBasenameNoExtension}.exe",
                "miDebuggerPath": "C:\\msys64\\ucrt64\\bin\\gdb.exe"
            },
            "linux": {
                "program": "${fileDirname}/executables/${fileBasenameNoExtension}",
                "miDebuggerPath": "gdb"
            }
        }
    ]
}