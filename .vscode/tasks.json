{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Current File",
      "type": "shell",
      "windows": {
        "command": ".\\scripts\\build.bat"
      },
      "linux": {
        "command": "./scripts/build.sh"
      },
      "args": ["${file}"],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      }
    },
    {
      "label": "Run Current File",
      "type": "shell",
      "windows": {
        "command": ".\\scripts\\run.bat"
      },
      "linux": {
        "command": "./scripts/run.sh"
      },
      "args": ["${file}"],
      "problemMatcher": [],
      "presentation": {
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      }
    }
  ]
}